						{
							"listen": "test",
							"script": {
								"exec": [
									"// Converte o body da resposta da API (JSON) em um objeto JavaScript\r",
									"const user = pm.response.json();\r",
									"\r",
									"// Teste para validar se a resposta contém as propriedades esperadas\r",
									"pm.test(\"Has properties\", function () {\r",
									"    // Verifica se o objeto retornado possui a propriedade 'email'\r",
									"    pm.expect(user).to.have.property('email');\r",
									"\r",
									"    // Verifica se o objeto retornado possui a propriedade 'token'\r",
									"    pm.expect(user).to.have.property('token');\r",
									"});\r",
									"\r",
									"// Verificação defensiva:\r",
									"if (user && user.token) {\r",
									"    // Salva o token retornado pela API em uma variável global do Postman\r",
									"    // Isso permite reutilizar o token em outras requisições (ex: Authorization Bearer)\r",
									"    pm.globals.set('token', user.token);\r",
									"}\r",
									""
								],
								"type": "text/javascript"
							}
						}
